# Local development — values from `pnpm db:start` (or `pnpm db:status`)
# Copy this file to .env.local and fill in after starting the local stack.
#
# Workflow:
#   pnpm db:start          → starts local Supabase (Docker required)
#   pnpm db:status         → prints the exact values to paste below
#   pnpm dev               → runs Next.js against the local DB

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<paste from db:status>
SUPABASE_SERVICE_ROLE_KEY=<paste from db:status>
